# Runtime
APP_ENV=development
LOG_LEVEL=INFO
SCAN_INTERVAL_SECONDS=30
MARKET_OPEN_HOUR_ET=9
MARKET_CLOSE_HOUR_ET=16

# Risk / strategy constraints
MIN_DOLLAR_VOLUME=5000000
MIN_RELATIVE_VOLUME=1.5
MIN_REWARD_TO_RISK=2.0
MAX_ACTIVE_POSITIONS=5
WATCHLIST=NVDA,TSLA,AMD,MSFT,AAPL,META,AMZN,QQQ
DYNAMIC_WATCHLIST_ENABLED=true
WATCHLIST_REFRESH_MINUTES=15
WATCHLIST_SIZE=20

# Trading mode
ALPACA_PAPER=true
ALPACA_LIVE_ENABLED=false
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Market data
POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.polygon.io

# Alerts
DISCORD_WEBHOOK_URL=

# Infrastructure
SQLITE_PATH=./breakoutbolt.db
REDIS_URL=redis://localhost:6379/0
